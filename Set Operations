# Read input for Set A and convert to a set of integers
input_a = input("Set A: ")
set_a = set(map(int, input_a.split()))

# Read input for Set B and convert to a set of integers
input_b = input("Set B: ")
set_b = set(map(int, input_b.split()))

# Perform Union operation
union_set = set_a.union(set_b)
print("Union:", union_set)

# Perform Intersection operation
intersection_set = set_a.intersection(set_b)
print("Intersection:", intersection_set)

# Perform Difference operation (A - B)
difference_set = set_a.difference(set_b)
print("Difference:", difference_set)
