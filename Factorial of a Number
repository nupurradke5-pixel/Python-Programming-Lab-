# Read input from the user
n = int(input())

# Initialize factorial to 1
factorial = 1

# Check if n is 0 or 1, as factorial of 0 or 1 is 1
if n < 0:
    pass # Factorial is not defined for negative numbers
elif n == 0:
    print(1)
else:
    # Use a loop to calculate the factorial
    for i in range(1, n + 1):
        factorial *= i
    print(factorial)
